{
  "_说明": "交易原则配置文件 - 可手动编辑调整买入/卖出/持有/清仓规则",
  "_版本": "1.0",
  "_最后修改": "2026-03-27",

  "交易哲学": {
    "核心理念": "达里奥全天候配置决定仓位比例，巴菲特价值投资决定标的选择",
    "风格": "稳健偏价值",
    "备注": "可在此自由添加你自己的投资理念笔记"
  },

  "买入规则": {
    "说明": "满足以下条件时触发买入/加仓信号，conditions中的项目为AND关系，any_of中的为OR关系",
    "conditions": [
      {
        "id": "B1",
        "名称": "综合评分达标",
        "条件": "composite_score >= 7.5",
        "权重": "必要条件",
        "启用": true,
        "说明": "五维综合评分需达到7.5以上才考虑买入"
      },
      {
        "id": "B2",
        "名称": "基本面过关",
        "条件": "fundamental_score >= 7.0",
        "权重": "必要条件",
        "启用": true,
        "说明": "巴菲特原则：不买基本面不好的股票"
      },
      {
        "id": "B3",
        "名称": "安全边际充足",
        "条件": "price <= intrinsic_value * 0.8",
        "权重": "强烈建议",
        "启用": true,
        "说明": "当前价低于内在价值的80%，即有20%安全边际"
      }
    ],
    "any_of": [
      {
        "id": "B4",
        "名称": "技术面支撑",
        "条件": "technical_score >= 6.5 OR price_near_support",
        "启用": true,
        "说明": "技术面不差或者价格在支撑位附近"
      },
      {
        "id": "B5",
        "名称": "资金面配合",
        "条件": "capital_score >= 7.0",
        "启用": true,
        "说明": "有主力或北向资金流入配合"
      }
    ],
    "加仓梯度": {
      "说明": "到达不同评分时的加仓幅度",
      "7.5-8.0": "+3%仓位",
      "8.0-8.5": "+5%仓位",
      "8.5-9.0": "+8%仓位",
      "9.0以上": "+10%仓位，最大不超过单票上限"
    }
  },

  "卖出规则": {
    "说明": "满足以下任一条件时触发卖出/减仓信号，为OR关系",
    "conditions": [
      {
        "id": "S1",
        "名称": "止损纪律",
        "条件": "pnl_pct <= stop_loss_pct",
        "优先级": "最高-强制执行",
        "启用": true,
        "说明": "亏损达到止损线必须执行，无例外。这是达里奥风控的核心"
      },
      {
        "id": "S2",
        "名称": "基本面恶化",
        "条件": "fundamental_score < 5.0",
        "优先级": "高",
        "启用": true,
        "说明": "基本面跌破5分，说明公司质量出问题，应减仓或清仓"
      },
      {
        "id": "S3",
        "名称": "估值过高",
        "条件": "pe_percentile > 90",
        "优先级": "中",
        "启用": true,
        "说明": "估值处于历史90%分位以上，考虑分批止盈"
      },
      {
        "id": "S4",
        "名称": "宏观象限恶化",
        "条件": "quadrant == '滞胀' AND macro_score < 3.0",
        "优先级": "高",
        "启用": true,
        "说明": "达里奥框架：滞胀环境对股票最不利，应主动降仓"
      },
      {
        "id": "S5",
        "名称": "综合评分持续下降",
        "条件": "composite_score < 5.0 AND 连续3日下降",
        "优先级": "中",
        "启用": true,
        "说明": "多维度持续走弱，趋势可能反转"
      }
    ],
    "减仓梯度": {
      "说明": "不同紧急程度的减仓幅度",
      "止损触发": "立即减至0%（清仓）",
      "高优先级": "减仓50%",
      "中优先级": "减仓25%-30%"
    }
  },

  "持有规则": {
    "说明": "满足以下条件时维持持仓不动",
    "conditions": [
      {
        "id": "H1",
        "名称": "评分在合理区间",
        "条件": "6.0 <= composite_score <= 8.0",
        "启用": true,
        "说明": "综合评分在6-8之间，不需要频繁操作"
      },
      {
        "id": "H2",
        "名称": "基本面稳定",
        "条件": "fundamental_score >= 6.0 AND 无重大负面事件",
        "启用": true,
        "说明": "巴菲特原则：好公司长期持有，不因短期波动卖出"
      },
      {
        "id": "H3",
        "名称": "仓位合理",
        "条件": "abs(current_weight - target_weight) < rebalance_threshold",
        "启用": true,
        "说明": "当前仓位偏离目标不超过再平衡阈值时无需调整"
      }
    ],
    "巴菲特提醒": "如果买入时的理由没有改变，就不要仅因为价格下跌而卖出"
  },

  "清仓规则": {
    "说明": "满足以下任一条件时必须清仓",
    "conditions": [
      {
        "id": "C1",
        "名称": "止损强制清仓",
        "条件": "pnl_pct <= stop_loss_pct * 1.5",
        "优先级": "最高-无条件执行",
        "启用": true,
        "说明": "亏损达到止损线1.5倍（如-12%），无论任何理由必须清仓"
      },
      {
        "id": "C2",
        "名称": "基本面崩塌",
        "条件": "fundamental_score < 3.0",
        "优先级": "最高",
        "启用": true,
        "说明": "基本面严重恶化（财务造假/核心业务崩溃等），不再具备持有价值"
      },
      {
        "id": "C3",
        "名称": "黑天鹅事件",
        "条件": "news_score < 2.0 AND 有重大负面不可逆事件",
        "优先级": "最高",
        "启用": true,
        "说明": "监管打击/退市风险/管理层严重丑闻等不可逆损害"
      },
      {
        "id": "C4",
        "名称": "综合评分极低",
        "条件": "composite_score < 4.0",
        "优先级": "高",
        "启用": true,
        "说明": "所有维度都在释放负面信号时，应果断退出"
      }
    ]
  },

  "仓位管理规则": {
    "达里奥全天候配置": {
      "说明": "根据宏观象限调整大类配置",
      "金发女孩": {"股票": "70-85%", "债券": "10-15%", "现金": "5-15%", "说明": "经济向好+通胀温和，全力配置风险资产"},
      "过热": {"股票": "50-65%", "债券": "10-15%", "商品": "10-15%", "现金": "15-20%", "说明": "注意通胀对估值的压制"},
      "衰退": {"股票": "30-45%", "债券": "25-35%", "现金": "25-35%", "说明": "防守为主，保留现金等待机会"},
      "滞胀": {"股票": "20-35%", "债券": "15-20%", "商品": "15-20%", "现金": "30-40%", "说明": "最危险的环境，大幅降仓"}
    },
    "再平衡触发": {
      "偏离阈值": "5%",
      "频率": "不超过每周1次",
      "说明": "当实际仓位偏离目标超过5%时触发再平衡"
    },
    "行业集中度": {
      "单行业上限": "40%",
      "说明": "避免同一行业过度集中"
    }
  },

  "特殊情境规则": {
    "财报季": {
      "规则": "财报发布前3天不建新仓，已有仓位可持有",
      "启用": true,
      "说明": "避免财报博弈，减少不确定性"
    },
    "FOMC会议": {
      "规则": "会议前后1天降低操作频率，观察市场反应再行动",
      "启用": true
    },
    "高VIX环境": {
      "规则": "VIX > 30时，暂停一切加仓操作，仅允许减仓和清仓",
      "启用": true,
      "说明": "极度恐慌时保存实力"
    },
    "连续涨停/跌停": {
      "规则": "A股标的连续涨停不追高，连续跌停不抄底",
      "启用": true
    }
  },

  "自定义规则": {
    "说明": "在这里添加你自己的交易规则，格式参考上面的conditions",
    "my_rules": [
      {
        "id": "MY1",
        "名称": "示例：不在周五尾盘加仓",
        "条件": "weekday != Friday OR time < 14:30",
        "启用": false,
        "说明": "周末有不确定性，周五不加仓"
      }
    ]
  }
}
